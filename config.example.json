{
  "auth_token": "replace-with-a-long-random-string",
  "listen_host": "0.0.0.0",
  "port": 8765,
  "receiver_url": "http://100.100.100.100:8765",
  "inbox_dir": "~/UnixDrop/inbox",
  "sync_dir": "~/UnixDrop/outbox",
  "link_log_path": "~/UnixDrop/link-log.jsonl",
  "state_dir": "~/.local/state/unixdrop",
  "auto_open_links": true,
  "clipboard_poll_seconds": 2,
  "file_poll_seconds": 5,
  "request_timeout_seconds": 15,
  "obsidian_enabled": false,
  "obsidian_vault_dir": "~/Obsidian/MainVault",
  "obsidian_poll_seconds": 10,
  "obsidian_excludes": [
    ".obsidian/workspace.json",
    ".obsidian/workspaces.json",
    ".obsidian/cache",
    ".trash"
  ]
}
